{
  "name": "online-invitation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test 'lib/**/*.test.ts'",
    "postinstall": "prisma generate",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "deploy": "bash deploy/remote-deploy.sh",
    "deploy:quick": "bash deploy/remote-deploy.sh --no-build",
    "deploy:push": "bash deploy/remote-deploy.sh --push",
    "deploy:logs": "bash deploy/remote-deploy.sh --logs",
    "deploy:status": "bash deploy/remote-deploy.sh --status"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.4.0",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@mui/material-nextjs": "^9.1.1",
    "@mui/x-data-grid": "^9.5.0",
    "@mui/x-date-pickers": "^9.5.0",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.101.0",
    "@vercel/blob": "^2.4.0",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.4.0",
    "grammy": "^1.44.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
