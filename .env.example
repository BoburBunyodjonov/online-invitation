# --- Database ---
# Local dev (SQLite — path is relative to prisma/schema.prisma):
DATABASE_URL="file:./dev.db"
# Production (Neon PostgreSQL — change prisma/schema.prisma provider to "postgresql"):
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth.js (NextAuth) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# --- Telegram ---
# Admin account username (NOT a bot) — visitors message this user to place orders
NEXT_PUBLIC_TELEGRAM_ADMIN_USERNAME="online_invitation_admin"

# Optional: Telegram BOT (only if you later set up automated order via @BotFather)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_ADMIN_CHAT_ID=""

# --- Vercel Blob storage ---
BLOB_READ_WRITE_TOKEN=""

# --- Site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_CONTACT_PHONE="+998 99 801 93 53"

# --- SEO (optional) ---
# Google Search Console HTML tag value
# GOOGLE_SITE_VERIFICATION=""
# Yandex Webmaster verification
# YANDEX_SITE_VERIFICATION=""

# --- Analytics (optional) ---
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=""
# Plausible domain (e.g. taklifnoma.uz)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# --- Error monitoring (optional) ---
# Webhook URL for production error reports (Slack, Discord, etc.)
# MONITORING_WEBHOOK_URL=""
