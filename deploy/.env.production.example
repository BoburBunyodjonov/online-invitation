# Copy to deploy/.env on the Hetzner server:
#   cp deploy/.env.production.example deploy/.env

# --- Domain (no trailing slash) ---
NEXT_PUBLIC_SITE_URL=https://YOUR_DOMAIN

# --- PostgreSQL (docker-compose internal) ---
POSTGRES_USER=taklifnoma
POSTGRES_PASSWORD=change-me-strong-password-here
POSTGRES_DB=taklifnoma

# --- Auth ---
# openssl rand -base64 32
AUTH_SECRET=

# --- Admin seed (first deploy only: RUN_SEED=true) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-admin-password
RUN_SEED=false

# --- Contact / Telegram ---
NEXT_PUBLIC_TELEGRAM_ADMIN_USERNAME=online_invitation_admin
NEXT_PUBLIC_CONTACT_PHONE=+998 99 801 93 53
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_CHAT_ID=

# --- Uploads (optional — leave empty to store files on server disk) ---
BLOB_READ_WRITE_TOKEN=

# --- SEO / Analytics (optional) ---
GOOGLE_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
MONITORING_WEBHOOK_URL=
